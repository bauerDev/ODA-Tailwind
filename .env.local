# NextAuth: requerida para encriptar los JWT. Cambiar este valor invalidará las sesiones existentes.
NEXTAUTH_SECRET=<secret>
NEXTAUTH_URL=<url>

# Google: para permitir login con Google.
GOOGLE_CLIENT_ID=<client_id>
GOOGLE_CLIENT_SECRET=<client_secret>

# PostgreSQL: para almacenar los datos de los usuarios.
PG_USER=<user_name>
PG_PASSWORD=<password>
PG_HOST=<host_name>
PG_DATABASE=<database_name>
PG_PORT=<port>

# Cloudinary: para subir imágenes.
CLOUDINARY_CLOUD_NAME=<cloud_name>
CLOUDINARY_API_KEY=<api_key>
CLOUDINARY_API_SECRET=<api_secret>

# OpenAI: para generar contenido.
OPENAI_API_KEY=<api_key>
OPENAI_MODEL=<model>

